{
  "schema_version": "v1",
  "name": "BookBuddy TTS",
  "description": "AI 读书伴侣 - 文本转语音插件。支持三种模式：基本 TTS、声音设计、声音克隆。让读书变成愉悦、享受、沉浸的体验。",
  "authentication": {
    "type": "bearer",
    "authorization_url": null,
    "scope": null
  },
  "logo": "https://cdn.xiaomimimo.com/icons/bookbuddy.png",
  "domains": [
    "api.xiaomimimo.com"
  ],
  "features": [
    {
      "type": "action",
      "name": "generate_audio",
      "description": "Convert text to speech audio using MiMo TTS API",
      "parameters": [
        {
          "name": "model",
          "type": "string",
          "required": false,
          "default": "mimo-v2.5-tts",
          "enum": [
            "mimo-v2.5-tts",
            "mimo-v2.5-tts-voicedesign",
            "mimo-v2.5-tts-voiceclone"
          ],
          "description": "TTS model to use"
        },
        {
          "name": "text",
          "type": "string",
          "required": true,
          "description": "Text to convert to speech"
        },
        {
          "name": "voice",
          "type": "string",
          "required": false,
          "enum": [
            "冰糖", "茉莉", "苏打", "白桦",
            "Mia", "Chloe", "Milo", "Dean"
          ],
          "description": "Built-in voice name (Basic TTS mode)"
        },
        {
          "name": "preset",
          "type": "string",
          "required": false,
          "enum": [
            "睡前催眠", "冥想引导", "深夜电台",
            "温柔叙述", "Her 知性元气", "悬疑小说"
          ],
          "description": "Voice design preset (Voice Design mode)"
        },
        {
          "name": "voice_reference_audio",
          "type": "string",
          "required": false,
          "description": "Reference audio for voice cloning (5+ seconds, MP3/WAV/M4A)"
        },
        {
          "name": "chunk_size",
          "type": "number",
          "required": false,
          "default": 300,
          "minimum": 50,
          "maximum": 500,
          "description": "Text chunk size for processing"
        }
      ]
    },
    {
      "type": "action",
      "name": "list_voices",
      "description": "Get list of available built-in voices",
      "parameters": []
    },
    {
      "type": "action",
      "name": "list_voice_presets",
      "description": "Get list of available voice design presets",
      "parameters": []
    }
  ],
  "privacy_policy_url": "https://github.com/lssuzie/bookbuddy/blob/main/README.md",
  "legal_info_url": "https://github.com/lssuzie/bookbuddy/blob/main/LICENSE",
  "capabilities": {
    "text_to_speech": true,
    "voice_cloning": true,
    "voice_design": true,
    "batch_processing": true
  },
  "pricing": {
    "type": "freemium",
    "free_quota": {
      "requests_per_month": 5,
      "max_text_length": 1000
    },
    "paid_plans": [
      {
        "name": "Pro",
        "price": 4.99,
        "currency": "USD",
        "billing_cycle": "monthly",
        "features": ["unlimited_requests", "all_voices", "voice_design", "voice_clone"]
      },
      {
        "name": "Enterprise",
        "price": 49.99,
        "currency": "USD",
        "billing_cycle": "monthly",
        "features": ["api_access", "custom_voice", "priority_support"]
      }
    ]
  },
  "support_url": "https://github.com/lssuzie/bookbuddy/issues",
  "documentation_url": "https://github.com/lssuzie/bookbuddy"
}