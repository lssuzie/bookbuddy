{
  "version": "1.0.0",
  "name": "BookBuddy TTS",
  "description": "AI 读书伴侣 - 文本转语音插件，支持三种模式：基本 TTS、声音设计、声音克隆",
  "author": "BookBuddy",
  "icon": "icon.png",
  "label": {
    "en_US": "BookBuddy TTS",
    "zh_CN": "BookBuddy TTS"
  },
  "categories": ["audio", "text-to-speech", "reading"],
  "plugin_declaration": {
    "type": "endpoint",
    "mode": "workflow",
    "icon": "icon.png",
    "icon_dark": "icon-dark.png"
  },
  "app_mode": "workflow",
  "icon_url": "https://cdn.xiaomimimo.com/icons/bookbuddy.png",
  "repository": "https://github.com/lssuzie/bookbuddy",
  "license": "MIT",
  "pricing": {
    "type": "freemium",
    "free_quota": 5,
    "paid_plans": [
      {
        "name": "Pro",
        "price": 9.9,
        "currency": "CNY",
        "billing_cycle": "monthly",
        "features": ["unlimited_requests", "all_voices", "voice_design", "voice_clone"]
      },
      {
        "name": "Enterprise",
        "price": 99,
        "currency": "CNY",
        "billing_cycle": "monthly",
        "features": ["api_access", "custom_voice", "priority_support"]
      }
    ]
  },
  "tools": [
    {
      "name": "generate_audio",
      "label": {
        "en_US": "Generate Audio",
        "zh_CN": "生成音频"
      },
      "description": {
        "en_US": "Convert text to speech audio using MiMo TTS API",
        "zh_CN": "使用 MiMo TTS API 将文本转换为音频"
      },
      "parameters": [
        {
          "name": "model",
          "label": {
            "en_US": "Model",
            "zh_CN": "模型"
          },
          "type": "string",
          "required": false,
          "default": "mimo-v2.5-tts",
          "options": [
            {"value": "mimo-v2.5-tts", "label": {"en_US": "Basic TTS", "zh_CN": "基本 TTS"}},
            {"value": "mimo-v2.5-tts-voicedesign", "label": {"en_US": "Voice Design", "zh_CN": "声音设计"}},
            {"value": "mimo-v2.5-tts-voiceclone", "label": {"en_US": "Voice Clone", "zh_CN": "声音克隆"}}
          ],
          "form": "llm",
          "human_description": {
            "en_US": "TTS model to use",
            "zh_CN": "使用的 TTS 模型"
          }
        },
        {
          "name": "text",
          "label": {
            "en_US": "Text",
            "zh_CN": "文本"
          },
          "type": "string",
          "required": true,
          "form": "llm",
          "human_description": {
            "en_US": "Text to convert to speech",
            "zh_CN": "要转换为语音的文本"
          }
        },
        {
          "name": "voice",
          "label": {
            "en_US": "Voice",
            "zh_CN": "音色"
          },
          "type": "string",
          "required": false,
          "options": [
            {"value": "冰糖", "label": {"en_US": "BingTang (Sweet)", "zh_CN": "冰糖 (甜美少女)"}},
            {"value": "茉莉", "label": {"en_US": "MoLi (Gentle)", "zh_CN": "茉莉 (温柔知性)"}},
            {"value": "苏打", "label": {"en_US": "SuDa (Sunny)", "zh_CN": "苏打 (阳光少年)"}},
            {"value": "白桦", "label": {"en_US": "BaiHua (Steady)", "zh_CN": "白桦 (沉稳男声)"}},
            {"value": "Mia", "label": {"en_US": "Mia (American)", "zh_CN": "Mia (美式女声)"}},
            {"value": "Chloe", "label": {"en_US": "Chloe (British)", "zh_CN": "Chloe (英式女声)"}},
            {"value": "Milo", "label": {"en_US": "Milo (American)", "zh_CN": "Milo (美式男声)"}},
            {"value": "Dean", "label": {"en_US": "Dean (British)", "zh_CN": "Dean (英式男声)"}}
          ],
          "form": "llm",
          "human_description": {
            "en_US": "Built-in voice name (Basic TTS mode)",
            "zh_CN": "内置音色名称（基本 TTS 模式）"
          }
        },
        {
          "name": "preset",
          "label": {
            "en_US": "Preset",
            "zh_CN": "预设"
          },
          "type": "string",
          "required": false,
          "options": [
            {"value": "睡前催眠", "label": {"en_US": "Bedtime Sleep", "zh_CN": "睡前催眠"}},
            {"value": "冥想引导", "label": {"en_US": "Meditation", "zh_CN": "冥想引导"}},
            {"value": "深夜电台", "label": {"en_US": "Late Night Radio", "zh_CN": "深夜电台"}},
            {"value": "温柔叙述", "label": {"en_US": "Gentle Narrative", "zh_CN": "温柔叙述"}},
            {"value": "Her 知性元气", "label": {"en_US": "Her Intelligent", "zh_CN": "Her 知性元气"}},
            {"value": "悬疑小说", "label": {"en_US": "Mystery Novel", "zh_CN": "悬疑小说"}}
          ],
          "form": "llm",
          "human_description": {
            "en_US": "Voice design preset (Voice Design mode)",
            "zh_CN": "声音设计预设（声音设计模式）"
          }
        },
        {
          "name": "voice_reference_audio",
          "label": {
            "en_US": "Reference Audio",
            "zh_CN": "参考音频"
          },
          "type": "file",
          "required": false,
          "form": "llm",
          "human_description": {
            "en_US": "Reference audio file for voice cloning (5+ seconds, MP3/WAV/M4A)",
            "zh_CN": "声音克隆的参考音频文件（5 秒以上，MP3/WAV/M4A）"
          }
        },
        {
          "name": "chunk_size",
          "label": {
            "en_US": "Chunk Size",
            "zh_CN": "分块大小"
          },
          "type": "number",
          "required": false,
          "default": 300,
          "min": 50,
          "max": 500,
          "form": "llm",
          "human_description": {
            "en_US": "Text chunk size for processing (default: 300)",
            "zh_CN": "文本分块大小（默认：300）"
          }
        }
      ]
    },
    {
      "name": "list_voices",
      "label": {
        "en_US": "List Voices",
        "zh_CN": "列出音色"
      },
      "description": {
        "en_US": "Get list of available built-in voices",
        "zh_CN": "获取可用内置音色列表"
      },
      "parameters": []
    },
    {
      "name": "list_voice_presets",
      "label": {
        "en_US": "List Voice Presets",
        "zh_CN": "列出声音预设"
      },
      "description": {
        "en_US": "Get list of available voice design presets",
        "zh_CN": "获取可用声音设计预设列表"
      },
      "parameters": []
    }
  ],
  "environment_variables": [
    {
      "name": "MIMO_API_KEY",
      "label": {
        "en_US": "MiMo API Key",
        "zh_CN": "MiMo API Key"
      },
      "type": "secret",
      "required": true,
      "description": {
        "en_US": "Your MiMo API Key (format: sk-xxxxxxxxxxxxxxxxxxxx)",
        "zh_CN": "你的 MiMo API Key（格式：sk-xxxxxxxxxxxxxxxxxxxx）"
      }
    }
  ],
  "schema_version": "v1"
}